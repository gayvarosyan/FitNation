<%@ taglib prefix="c" uri="http://java.sun.com/jsp/jstl/core" %>
<c:set var="ctx" value="${pageContext.request.contextPath}" />
<aside class="fn-portal-sidebar">
  <div class="fn-portal-brand">
    <div class="fn-portal-brand-icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M20.57 14.86L22 13.43 20.57 12 17 15.57 8.43 7 12 3.43 10.57 2 9.14 3.43 7.71 2 5.57 4.14 4.14 2.71 2 4.86l1.43 1.43L2 7.71l1.43 1.43L2 10.57 3.43 12 7 8.43 15.57 17 12 20.57 13.43 22l1.43-1.43L16.29 22l2.14-2.14 1.43 1.43L22 19.14l-1.43-1.43L22 16.29z"/>
      </svg>
    </div>
    <span class="fn-portal-brand-text">FitNation</span>
  </div>
  <nav class="fn-portal-nav" aria-label="Main navigation">
    <a href="${ctx}/portal" class="fn-portal-nav-item ${navSection == 'home' ? 'active' : ''}">
      <span class="fn-portal-nav-icon" aria-hidden="true">▣</span>
      <span class="fn-portal-nav-label">Dashboard</span>
    </a>
    <a href="${ctx}/portal/subscriptions" class="fn-portal-nav-item ${navSection == 'subscriptions' ? 'active' : ''}">
      <span class="fn-portal-nav-icon" aria-hidden="true">💳</span>
      <span class="fn-portal-nav-label">Subscription</span>
    </a>
    <a href="${ctx}/portal/bookings" class="fn-portal-nav-item ${navSection == 'bookings' ? 'active' : ''}">
      <span class="fn-portal-nav-icon" aria-hidden="true">🗓️</span>
      <span class="fn-portal-nav-label">Bookings</span>
    </a>
    <a href="${ctx}/portal/chat" class="fn-portal-nav-item ${navSection == 'chat' ? 'active' : ''}">
      <span class="fn-portal-nav-icon" aria-hidden="true">💬</span>
      <span class="fn-portal-nav-label">Chat</span>
    </a>
    <a href="${ctx}/portal/progress" class="fn-portal-nav-item ${navSection == 'progress' ? 'active' : ''}">
      <span class="fn-portal-nav-icon" aria-hidden="true">📈</span>
      <span class="fn-portal-nav-label">Progress</span>
    </a>
    <a href="${ctx}/portal/profile" class="fn-portal-nav-item ${navSection == 'profile' ? 'active' : ''}">
      <span class="fn-portal-nav-icon" aria-hidden="true">👤</span>
      <span class="fn-portal-nav-label">Profile</span>
    </a>
    <a href="${ctx}/portal/device-login" class="fn-portal-nav-item ${navSection == 'device-login' ? 'active' : ''}">
      <span class="fn-portal-nav-icon" aria-hidden="true">📱</span>
      <span class="fn-portal-nav-label">Device Login</span>
    </a>
  </nav>
  <div class="fn-portal-sidebar-footer">
    <form method="post" action="${ctx}/logout" class="d-inline">
      <button type="submit" class="fn-portal-logout-btn">Logout</button>
    </form>
  </div>
</aside>
