<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="009-create-trainer-schedule-table" author="MariamHovhannisyan">
        <createTable tableName="trainer_schedule">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_trainer_schedule"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_trainer_schedule_trainer" references="trainers(id)"/>
            </column>
            <column name="available_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="end_time" type="TIME">
                <constraints nullable="false"/>
            </column>
            <column name="is_booked" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
