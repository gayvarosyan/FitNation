<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="007-create-membership-freeze-requests-table" author="MariamHovhannisyan">
        <createTable tableName="membership_freeze_requests">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_membership_freeze_requests"/>
            </column>
            <column name="membership_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_freeze_requests_membership" references="memberships(id)"/>
            </column>
            <column name="freeze_start" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="freeze_end" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="freeze_request_status" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="reviewed_by" type="BIGINT">
                <constraints foreignKeyName="fk_freeze_requests_reviewed_by" references="users(id)"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="now()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
