<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="034-soft-delete-users" author="Meri">
        <sql>ALTER TYPE user_status ADD VALUE IF NOT EXISTS 'DELETED';</sql>
        <addColumn tableName="users">
            <column name="deleted_at" type="TIMESTAMP" defaultValue="null">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <rollback>
            <dropColumn tableName="users" columnName="deleted_at"/>
        </rollback>
    </changeSet>

</databaseChangeLog>