<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="040-create-in-app-notifications" author="Gayane">
        <createTable tableName="in_app_notifications">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_in_app_notifications"/>
            </column>
            <column name="recipient_user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_in_app_notifications_recipient"
                             references="users(id)"/>
            </column>
            <column name="event_type" type="VARCHAR(80)">
                <constraints nullable="false"/>
            </column>
            <column name="title" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="body" type="VARCHAR(4000)">
                <constraints nullable="false"/>
            </column>
            <column name="is_read" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="metadata_json" type="VARCHAR(8000)">
                <constraints nullable="false"/>
            </column>
            <column name="severity" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="VARCHAR(80)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="in_app_notifications" indexName="idx_in_app_notifications_recipient_created">
            <column name="recipient_user_id"/>
            <column name="created_at"/>
        </createIndex>

        <createIndex tableName="in_app_notifications" indexName="idx_in_app_notifications_dedup">
            <column name="recipient_user_id"/>
            <column name="event_type"/>
            <column name="entity_type"/>
            <column name="entity_id"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
