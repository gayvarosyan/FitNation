<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="033-1-membership-request-status-enum" author="fitnation">
        <sql>CREATE TYPE membership_request_status AS ENUM ('PENDING', 'APPROVED', 'REJECTED');</sql>
        <rollback>
            <sql>DROP TYPE IF EXISTS membership_request_status;</sql>
        </rollback>
    </changeSet>

    <changeSet id="033-2-create-membership-requests-table" author="fitnation">
        <createTable tableName="membership_requests">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_membership_requests"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="membership_type_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="membership_request_status">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="reviewed_at" type="TIMESTAMP"/>
            <column name="reviewed_by_user_id" type="BIGINT"/>
            <column name="rejection_reason" type="TEXT"/>
        </createTable>
        <addForeignKeyConstraint baseTableName="membership_requests" baseColumnNames="user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_membership_requests_user"/>
        <addForeignKeyConstraint baseTableName="membership_requests" baseColumnNames="membership_type_id"
                                 referencedTableName="membership_types" referencedColumnNames="id"
                                 constraintName="fk_membership_requests_membership_type"/>
        <addForeignKeyConstraint baseTableName="membership_requests" baseColumnNames="reviewed_by_user_id"
                                 referencedTableName="users" referencedColumnNames="id"
                                 constraintName="fk_membership_requests_reviewed_by"/>
        <sql>
            CREATE UNIQUE INDEX uk_membership_request_pending_per_user_type
            ON membership_requests (user_id, membership_type_id)
            WHERE status = 'PENDING';
        </sql>
        <rollback>
            <sql>DROP INDEX IF EXISTS uk_membership_request_pending_per_user_type;</sql>
            <dropTable tableName="membership_requests"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
