<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="015-create-workout-plans-table" author="MariamHovhannisyan">
        <createTable tableName="workout_plans">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_workout_plans"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints foreignKeyName="fk_workout_plans_trainer" references="trainers(id)"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints foreignKeyName="fk_workout_plans_user" references="users(id)"/>
            </column>
            <column name="title" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="now()"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
