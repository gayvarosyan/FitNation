<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="035-add-rejection-reason-to-membership-freeze-requests" author="MariamHovhannisyan">
        <addColumn tableName="membership_freeze_requests">
            <column name="rejection_reason" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <addColumn tableName="membership_freeze_requests">
            <column name="reviewed_at" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
