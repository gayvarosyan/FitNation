<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="030-fix-group-classes-trainer-fk-to-user-id" author="fitnation">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="group_classes"/>
            <tableExists tableName="trainers"/>
            <columnExists tableName="group_classes" columnName="trainer_id"/>
            <columnExists tableName="trainers" columnName="user_id"/>
        </preConditions>

        <sql>
            ALTER TABLE group_classes DROP CONSTRAINT IF EXISTS fk_group_classes_trainer;
        </sql>

        <addForeignKeyConstraint
                baseTableName="group_classes"
                baseColumnNames="trainer_id"
                referencedTableName="trainers"
                referencedColumnNames="user_id"
                constraintName="fk_group_classes_trainer"/>
    </changeSet>
</databaseChangeLog>