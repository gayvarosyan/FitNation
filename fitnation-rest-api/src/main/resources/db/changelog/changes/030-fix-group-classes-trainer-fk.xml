<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="027-create-group-classes" author="Gayane">
        <createTable tableName="group_classes">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="name" type="VARCHAR(255)"/>
            <column name="description" type="TEXT"/>
            <column name="capacity" type="INT"/>

            <column name="trainer_id" type="BIGINT"/>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="group_classes"
                baseColumnNames="trainer_id"
                referencedTableName="trainers"
                referencedColumnNames="id"
                constraintName="fk_group_classes_trainer"/>
    </changeSet>
</databaseChangeLog>