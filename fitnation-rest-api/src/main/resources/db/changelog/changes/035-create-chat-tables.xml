<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="034-1-create-chat-conversations-table" author="Meri">
        <createTable tableName="chat_conversations">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_chat_conversations"/>
            </column>
            <column name="client_user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="trainer_user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="last_message_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="chat_conversations" baseColumnNames="client_user_id"
                referencedTableName="users" referencedColumnNames="id"
                constraintName="fk_chat_conv_client"/>

        <addForeignKeyConstraint
                baseTableName="chat_conversations" baseColumnNames="trainer_user_id"
                referencedTableName="users" referencedColumnNames="id"
                constraintName="fk_chat_conv_trainer"/>

        <addUniqueConstraint
                tableName="chat_conversations"
                columnNames="client_user_id, trainer_user_id"
                constraintName="uq_chat_conversation"/>

        <createIndex tableName="chat_conversations" indexName="idx_conv_client">
            <column name="client_user_id"/>
        </createIndex>

        <createIndex tableName="chat_conversations" indexName="idx_conv_trainer">
            <column name="trainer_user_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="chat_conversations"/>
        </rollback>
    </changeSet>

    <changeSet id="034-2-create-chat-messages-table" author="fitnation">
        <createTable tableName="chat_messages">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_chat_messages"/>
            </column>
            <column name="conversation_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="sender_user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="body" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="read_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="chat_messages" baseColumnNames="conversation_id"
                referencedTableName="chat_conversations" referencedColumnNames="id"
                constraintName="fk_chat_msg_conversation"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="chat_messages" baseColumnNames="sender_user_id"
                referencedTableName="users" referencedColumnNames="id"
                constraintName="fk_chat_msg_sender"/>

        <createIndex tableName="chat_messages" indexName="idx_msg_conv_time">
            <column name="conversation_id"/>
            <column name="created_at"/>
        </createIndex>

        <rollback>
            <dropTable tableName="chat_messages"/>
        </rollback>
    </changeSet>

</databaseChangeLog>