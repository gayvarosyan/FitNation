<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">
    <changeSet id="029-create-class-bookings" author="Gayane">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="class_bookings"/>
            </not>
        </preConditions>
        <createTable tableName="class_bookings">

            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>

            <column name="class_schedule_id" type="BIGINT"/>
            <column name="user_id" type="BIGINT"/>

            <column name="status" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"/>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="class_bookings"
                baseColumnNames="class_schedule_id"
                referencedTableName="class_schedule"
                referencedColumnNames="id"
                constraintName="fk_booking_schedule"/>

        <addForeignKeyConstraint
                baseTableName="class_bookings"
                baseColumnNames="user_id"
                referencedTableName="users"
                referencedColumnNames="id"
                constraintName="fk_booking_user"/>
    </changeSet>

</databaseChangeLog>