<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="028-membership-bundle-links" author="fitnation">
        <addColumn tableName="membership_types">
            <column name="nutrition_plan_id" type="BIGINT"/>
            <column name="trainer_id" type="BIGINT"/>
            <column name="group_class_id" type="BIGINT"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="membership_types" baseColumnNames="nutrition_plan_id"
                                 constraintName="fk_membership_types_nutrition_plan"
                                 referencedTableName="nutrition_plans" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="membership_types" baseColumnNames="trainer_id"
                                 constraintName="fk_membership_types_trainer"
                                 referencedTableName="trainers" referencedColumnNames="user_id"/>
        <addForeignKeyConstraint baseTableName="membership_types" baseColumnNames="group_class_id"
                                 constraintName="fk_membership_types_group_class"
                                 referencedTableName="group_classes" referencedColumnNames="id"/>

        <addColumn tableName="memberships">
            <column name="nutrition_plan_id" type="BIGINT"/>
            <column name="trainer_id" type="BIGINT"/>
            <column name="group_class_id" type="BIGINT"/>
        </addColumn>
        <addForeignKeyConstraint baseTableName="memberships" baseColumnNames="nutrition_plan_id"
                                 constraintName="fk_memberships_nutrition_plan"
                                 referencedTableName="nutrition_plans" referencedColumnNames="id"/>
        <addForeignKeyConstraint baseTableName="memberships" baseColumnNames="trainer_id"
                                 constraintName="fk_memberships_trainer"
                                 referencedTableName="trainers" referencedColumnNames="user_id"/>
        <addForeignKeyConstraint baseTableName="memberships" baseColumnNames="group_class_id"
                                 constraintName="fk_memberships_group_class"
                                 referencedTableName="group_classes" referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
