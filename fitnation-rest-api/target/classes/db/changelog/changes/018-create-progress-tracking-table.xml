<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="018-create-progress-tracking-table" author="MariamHovhannisyan">
        <createTable tableName="progress_tracking">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_progress_tracking"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_progress_tracking_user" references="users(id)"/>
            </column>
            <column name="weight" type="DECIMAL(10,2)"/>
            <column name="workouts_count" type="INT" defaultValueNumeric="0"/>
            <column name="visits_count" type="INT" defaultValueNumeric="0"/>
            <column name="recorded_at" type="TIMESTAMP" defaultValueComputed="now()"/>
            <column name="notes" type="TEXT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>
