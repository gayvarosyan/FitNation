<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="021-create-favorites-table" author="MariamHovhannisyan">
        <createTable tableName="favorites">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_favorites"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_favorites_user" references="users(id)"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints foreignKeyName="fk_favorites_trainer" references="trainers(id)"/>
            </column>
            <column name="class_id" type="BIGINT">
                <constraints foreignKeyName="fk_favorites_class" references="group_classes(id)"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
